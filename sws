  return (
    <div className="min-h-screen bg-[#050B14] text-slate-200 p-4 md:p-8 font-sans selection:bg-indigo-500/30 overflow-hidden relative flex flex-col" onPointerMove={handlePointerMove} onPointerUp={handlePointerUp} onPointerLeave={handlePointerUp}>
      <div className="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-indigo-900/20 via-[#050B14] to-[#050B14] z-0 pointer-events-none"></div>
      <div className="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_70%,transparent_100%)] z-0 pointer-events-none"></div>

      <style>{`@keyframes dash { to { stroke-dashoffset: -30; } }`}</style>

      {/* --- HEADER --- */}
      <header className="relative z-20 flex flex-col xl:flex-row justify-between items-start xl:items-center mb-6 bg-slate-900/50 backdrop-blur-md p-6 rounded-2xl border border-slate-800/80 shadow-2xl gap-6">
        <div className="flex flex-col md:flex-row items-start md:items-center gap-6">
          <div className="flex items-center gap-4">
            <div className="p-3 bg-indigo-500/10 rounded-xl border border-indigo-500/30"><Cpu className="text-indigo-400" size={28} /></div>
            <div>
              <h1 className="text-2xl font-black text-white tracking-wide">HR ARCHITECTURE MAP</h1>
              <div className="flex flex-wrap items-center gap-2 mt-1">
                <span className={`text-[10px] px-2 py-0.5 rounded font-bold border flex items-center gap-1 uppercase ${viewMode === 'admin' ? 'bg-red-500/20 text-red-300 border-red-500/30' : 'bg-emerald-500/20 text-emerald-300 border-emerald-500/30'}`}>
                  {viewMode === 'admin' ? <Unlock size={10} /> : <Lock size={10} />} {viewMode === 'admin' ? 'Admin Workspace' : 'Presentation View'}
                </span>
                
                {viewMode === 'admin' && (
                  <div className="flex gap-1">
                    <button onClick={addEntity} className="bg-indigo-600/50 hover:bg-indigo-500 text-white text-[10px] px-2 py-0.5 rounded font-bold transition-colors"> + ENTITY </button>
                    <button onClick={addRole} className="bg-indigo-500/30 hover:bg-indigo-400/80 text-white text-[10px] px-2 py-0.5 rounded font-bold transition-colors"> + ROLE </button>
                    <button onClick={addTask} className="bg-indigo-500/20 hover:bg-indigo-400/60 text-white text-[10px] px-2 py-0.5 rounded font-bold transition-colors"> + TASK </button>
                  </div>
                )}
              </div>
            </div>
          </div>
          
          <div className="flex bg-slate-950 p-1 rounded-lg border border-slate-800">
            <button onClick={() => setViewMode('admin')} className={`flex items-center gap-2 px-4 py-2 text-xs font-bold rounded-md transition-all ${viewMode === 'admin' ? 'bg-indigo-600 text-white shadow-lg' : 'text-slate-400 hover:text-white hover:bg-slate-800'}`}><Unlock size={14} /> Workspace</button>
            <button onClick={() => setViewMode('presentation')} className={`flex items-center gap-2 px-4 py-2 text-xs font-bold rounded-md transition-all ${viewMode === 'presentation' ? 'bg-indigo-600 text-white shadow-lg' : 'text-slate-400 hover:text-white hover:bg-slate-800'}`}><Network size={14} /> Map View</button>
            <button onClick={() => setViewMode('dashboard')} className={`flex items-center gap-2 px-4 py-2 text-xs font-bold rounded-md transition-all ${viewMode === 'dashboard' ? 'bg-indigo-600 text-white shadow-lg' : 'text-slate-400 hover:text-white hover:bg-slate-800'}`}><BarChart3 size={14} /> Analysis</button>
          </div>
        </div>
        
        <div className="flex flex-wrap gap-4 w-full xl:w-auto">
          {viewMode !== 'dashboard' && (
             <button onClick={handleSnapToGrid} className="flex-1 xl:flex-none flex items-center justify-center gap-2 px-4 py-3 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl font-bold text-sm text-slate-300 transition-all">
                <LayoutTemplate size={18} /> Nice Arrange
             </button>
          )}
          
          <button 
            onClick={() => setShowSolution(!showSolution)}
            className={`flex-1 xl:flex-none group relative px-6 py-3 rounded-xl font-bold text-sm tracking-wide transition-all duration-500 overflow-hidden border ${
              showSolution 
                ? 'bg-slate-800 border-slate-600 text-slate-300 hover:bg-slate-700' 
                : 'bg-emerald-600 border-emerald-400 text-white hover:bg-emerald-500 shadow-[0_0_20px_rgba(16,185,129,0.4)]'
            }`}
          >
            <div className="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
            <span className="flex justify-center items-center gap-2 relative z-10 whitespace-nowrap">
              {showSolution ? <ArrowRight size={18} className="rotate-180" /> : <Zap size={18} />}
              {showSolution ? 'REVERT STATE' : 'RESTRUCTURE SYSTEM'}
            </span>
          </button>
        </div>
      </header>

      {/* --- CONTENT --- */}
      {viewMode === 'admin' || viewMode === 'presentation' ? (
        <div className="relative flex-1 w-full bg-slate-950/40 rounded-3xl border border-slate-800/60 shadow-2xl overflow-hidden backdrop-blur-sm touch-none">
          <div ref={containerRef} className="absolute inset-0 w-full h-full transform transition-transform duration-200 ease-out" style={{ transform: `scale(${zoomLevel})`, transformOrigin: 'center center' }}>
            {Object.entries(data).map(([key, nodeData]) => {
              if (nodeData.type !== 'role' || (key === 'newExec' && !showSolution)) return null;
              const parentEntities = Array.isArray(nodeData.reportsTo) ? nodeData.reportsTo : [];
              return parentEntities.map(entKey => coords[entKey] ? <Connection key={`report-${key}-${entKey}`} start={coords[entKey]} end={coords[key]} color="#94A3B8" isReporting={true} /> : null);
            })}
            
            {Object.entries(data).map(([key, nodeData]) => {
              if (nodeData.type !== 'task') return null;
              const ownerKey = (showSolution && nodeData.reallocatedTo) ? nodeData.reallocatedTo : nodeData.belongsTo;
              const owner = data[ownerKey];
              if (owner && owner.isExpanded && coords[ownerKey]) {
                const lineColor = (showSolution && nodeData.reallocatedTo) ? "#4ADE80" : (nodeData.strainTheme ? (nodeData.strainTheme === 'red' ? '#EF4444' : '#F97316') : "#6366F1");
                return <Connection key={`taskconn-${key}`} start={coords[ownerKey]} end={coords[key]} color={lineColor} pulsing={true} delay={`${Math.random()}s`} />;
              }
              return null;
            })}

            {Object.entries(data).map(([key, nodeData]) => {
              if (nodeData.isSolution && !showSolution) return null;
              let isVisible = true;
              if (nodeData.type === 'task') {
                const ownerKey = (showSolution && nodeData.reallocatedTo) ? nodeData.reallocatedTo : nodeData.belongsTo;
                const owner = data[ownerKey];
                if (!owner || !owner.isExpanded) isVisible = false;
              }
              return renderNode(key, isVisible);
            })}
          </div>

          <div className="absolute bottom-6 left-6 flex items-center bg-slate-900/90 backdrop-blur-md border border-slate-700/80 rounded-xl shadow-2xl z-30 p-1">
            <button onClick={() => setZoomLevel(prev => Math.max(0.4, prev - 0.15))} className="p-2 hover:bg-slate-800 rounded-lg text-slate-400 hover:text-white transition-colors"><ZoomOut size={20} /></button>
            <button onClick={() => setZoomLevel(1)} className="px-3 py-2 text-xs font-bold text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors">{Math.round(zoomLevel * 100)}%</button>
            <button onClick={() => setZoomLevel(prev => Math.min(2, prev + 0.15))} className="p-2 hover:bg-slate-800 rounded-lg text-slate-400 hover:text-white transition-colors"><ZoomIn size={20} /></button>
          </div>

          <div className={`absolute top-6 right-6 w-80 bg-slate-900/95 backdrop-blur-xl border border-slate-700/80 rounded-2xl shadow-2xl z-30 transition-all duration-300 flex flex-col ${showSidebar ? 'translate-x-0 opacity-100' : 'translate-x-[110%] opacity-0'}`} style={{ maxHeight: '80vh' }}>
            <div className="p-4 border-b border-slate-800/80 flex items-center justify-between">
              <div className="flex items-center gap-2 text-slate-200 font-bold text-sm"><ListChecks size={16} className="text-indigo-400" /> Map Insights</div>
              <button onClick={() => setShowSidebar(false)} className="text-slate-500 hover:text-slate-300 transition-colors"><ChevronDown size={16} className="rotate-[-90deg]" /></button>
            </div>
            <div className="flex p-2 gap-1 bg-slate-950/50 border-b border-slate-800/80">
              <button onClick={() => setSidebarTab('roles')} className={`flex-1 py-1.5 text-[10px] font-bold uppercase tracking-wider rounded transition-colors ${sidebarTab === 'roles' ? 'bg-indigo-600 text-white' : 'text-slate-400 hover:bg-white/5'}`}>Workload</button>
              <button onClick={() => setSidebarTab('entities')} className={`flex-1 py-1.5 text-[10px] font-bold uppercase tracking-wider rounded transition-colors ${sidebarTab === 'entities' ? 'bg-indigo-600 text-white' : 'text-slate-400 hover:bg-white/5'}`}>Entities</button>
            </div>
            <div className="p-4 space-y-4 overflow-y-auto custom-scrollbar flex-1 text-left">
              {sidebarTab === 'roles' && roleHoursSummary.map(role => (
                <div key={role.key} className="bg-slate-950/50 rounded-xl p-3 border border-white/5">
                  <div className="flex justify-between items-end mb-1">
                    <span className="text-xs font-bold text-slate-300 truncate pr-2">{role.title}</span>
                    <span className={`text-xs font-black ${role.hours > 40 ? 'text-red-400' : 'text-emerald-400'}`}>{role.hours}h</span>
                  </div>
                  <div className="w-full bg-slate-800 rounded-full h-1.5 overflow-hidden"><div className={`h-full transition-all duration-500 ${role.hours > 40 ? 'bg-red-500' : 'bg-emerald-500'}`} style={{ width: `${Math.min((role.hours/60)*100, 100)}%` }} /></div>
                </div>
              ))}
              {sidebarTab === 'entities' && entityHoursSummary.map((ent, idx) => (
                <div key={idx} className="bg-slate-950/50 rounded-xl p-3 border border-white/5 flex items-center justify-between">
                  <span className={`text-[10px] font-bold px-2 py-0.5 rounded-full border ${ENTITY_COLORS[ent.entity] || ENTITY_COLORS['Corporate/All']}`}>{ent.entity}</span>
                  <div className="text-sm font-black text-slate-400">{ent.hours}h</div>
                </div>
              ))}
            </div>
          </div>
          {!showSidebar && <button onClick={() => setShowSidebar(true)} className="absolute top-6 right-0 bg-slate-900/95 border border-r-0 border-slate-700/80 rounded-l-xl p-3 shadow-2xl z-30 text-slate-400 hover:text-white transition-colors"><ListChecks size={20} /></button>}
        </div>
      ) : (
        // DASHBOARD VIEW
        <div className="flex-1 w-full bg-slate-950/80 rounded-3xl border border-slate-800/80 shadow-2xl overflow-y-auto p-4 md:p-8 custom-scrollbar relative z-10">
          <div className="max-w-6xl mx-auto space-y-6 animate-in fade-in zoom-in-95 duration-300">
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div className="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-lg text-left">
                <div className="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-2 flex items-center gap-2"><Target size={14} className="text-indigo-400"/> Total Work Load</div>
                <div className="text-3xl font-black text-white">{totalLoad.toFixed(1)}<span className="text-sm text-slate-500 font-bold ml-1">hrs/wk</span></div>
              </div>
              <div className="bg-slate-900 border border-slate-800 rounded-2xl p-5 shadow-lg text-left">
                <div className="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-2 flex items-center gap-2"><Users size={14} className="text-indigo-400"/> System Capacity</div>
                <div className="text-3xl font-black text-white">{totalCapacity.toFixed(1)}<span className="text-sm text-slate-500 font-bold ml-1">hrs/wk</span></div>
              </div>
              <div className={`bg-slate-900 border rounded-2xl p-5 shadow-lg transition-colors duration-500 text-left ${isSystemOverloaded ? 'border-red-500/50 shadow-[0_0_20px_rgba(239,68,68,0.1)]' : 'border-emerald-500/50'}`}>
                <div className="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-2 flex items-center gap-2"><Activity size={14} className={isSystemOverloaded ? 'text-red-400' : 'text-emerald-400'}/> Utilization Rate</div>
                <div className={`text-3xl font-black ${isSystemOverloaded ? 'text-red-400' : 'text-emerald-400'}`}>{utilizationRate}%</div>
                <div className="w-full bg-slate-800 h-1.5 mt-3 rounded-full overflow-hidden">
                  <div className={`h-full transition-all duration-1000 ${isSystemOverloaded ? 'bg-red-500' : 'bg-emerald-500'}`} style={{ width: `${Math.min(utilizationRate, 100)}%`}}></div>
                </div>
              </div>
              <div className={`bg-slate-900 border rounded-2xl p-5 shadow-lg transition-colors duration-500 text-left ${isSystemOverloaded ? 'border-red-500/50 bg-red-950/20' : 'border-slate-800'}`}>
                <div className="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-2 flex items-center gap-2">
                  {isSystemOverloaded ? <AlertCircle size={14} className="text-red-400 animate-pulse"/> : <ShieldCheck size={14} className="text-emerald-400"/>} System Status
                </div>
                <div className={`text-3xl font-black ${isSystemOverloaded ? 'text-red-400' : 'text-slate-300'}`}>
                  {missingFTEsString}
                  <span className="text-sm text-slate-500 font-bold ml-1">Missing FTEs</span>
                </div>
              </div>
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 text-left">
              <div className="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-lg">
                <h2 className="text-sm font-bold text-white mb-6 uppercase tracking-widest flex items-center gap-2">
                  <Briefcase size={16} className="text-indigo-400" /> Workload by Position
                </h2>
                <div className="space-y-6">
                  {roleHoursSummary.map(role => (
                    <div key={role.key} className="relative">
                      <div className="flex justify-between items-end mb-2">
                        <span className="text-sm font-bold text-slate-200">{role.title}</span>
                        <span className={`text-sm font-black font-mono ${role.hours > 40 ? 'text-red-400' : 'text-emerald-400'}`}>{role.hours}h</span>
                      </div>
                      <div className="w-full bg-slate-800 rounded-full h-3 relative">
                        <div className="absolute top-0 bottom-0 border-l-2 border-red-500/50 border-dashed z-10" style={{ left: `${(40 / 60) * 100}%` }}></div>
                        <div className={`h-full rounded-full transition-all duration-1000 ease-out ${role.hours > 40 ? 'bg-red-500' : 'bg-emerald-500'}`} style={{ width: `${Math.min((role.hours/60)*100, 100)}%` }} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              <div className="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-lg">
                <h2 className="text-sm font-bold text-white mb-6 uppercase tracking-widest flex items-center gap-2">
                  <Building2 size={16} className="text-indigo-400" /> Entity Resource Consumption
                </h2>
                <div className="space-y-4">
                  {entityHoursSummary.map((ent, i) => (
                    <div key={i} className="flex items-center gap-4">
                      <div className={`w-32 text-xs font-bold px-2 py-1 rounded-full border text-center truncate flex-shrink-0 ${ENTITY_COLORS[ent.entity] || ENTITY_COLORS['Corporate/All']}`}>{ent.entity}</div>
                      <div className="flex-1 flex items-center gap-3">
                        <div className="flex-1 bg-slate-800 rounded-full h-2">
                          <div className="bg-indigo-500 h-full rounded-full transition-all duration-1000" style={{ width: `${totalLoad > 0 ? (ent.hours / totalLoad) * 100 : 0}%` }}></div>
                        </div>
                        <span className="w-12 text-right text-sm font-black font-mono text-slate-300">{ent.hours}h</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
