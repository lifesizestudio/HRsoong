// --- SVG CONNECTION LINES COMPONENT ---
const Connection = ({ start, end, color, pulsing, isReporting = false, delay = '0s' }) => {
  if (!start || !end) return null;
  const isDownward = start.y <= end.y;
  const offsetY = 4; 
  const sY = isDownward ? start.y + offsetY : start.y - offsetY;
  const eY = isDownward ? end.y - offsetY : end.y + offsetY;
  const midY = (sY + eY) / 2;
  const path = `M ${start.x} ${sY} C ${start.x} ${midY}, ${end.x} ${midY}, ${end.x} ${eY}`;

  return (
    <svg className="absolute inset-0 w-full h-full pointer-events-none z-0" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path 
        d={path} fill="none" stroke={color} strokeWidth={isReporting ? "0.2" : "0.25"} 
        strokeLinecap="round" strokeDasharray={isReporting ? "2 4" : "none"} 
        className={`${isReporting ? 'opacity-30' : 'opacity-15'} transition-all duration-500 ease-out`}
      />
      {pulsing && !isReporting && (
        <path 
          d={path} fill="none" stroke={color} strokeWidth="0.5" strokeLinecap="round" strokeDasharray="6 12"
          className="animate-[dash_3s_linear_infinite] transition-all duration-500 ease-out opacity-80" 
          style={{ animationDelay: delay }}
        />
      )}
    </svg>
  );
};

